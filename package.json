{
  "name": "riffle",
  "version": "0.1.0",
  "description": "Page-turning book viewer with show-through translucency.",
  "type": "module",
  "main": "dist/riffle.min.js",
  "module": "dist/riffle.min.js",
  "exports": {
    ".": {
      "import": "./dist/riffle.min.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=esm --minify --sourcemap --outfile=dist/riffle.min.js && esbuild src/loading/pdfWorker.js --bundle --format=esm --minify --sourcemap --outfile=dist/pdfWorker.js",
    "docs:api": "node scripts/build-api-docs.mjs",
    "docs": "npm run docs:api"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "glob": "^13.0.6",
    "jsdoc-to-markdown": "^9.1.3"
  }
}
